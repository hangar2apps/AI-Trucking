SUPABASE_PASSWORD=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
# Verified Resend sender. The onboarding default only delivers to your own
# Resend account email; use a verified domain to reach any recipient.
RESEND_FROM=A-TMS (Aurora Freight) <onboarding@resend.dev>
# Seed customer emails are fake — set this to route all outbound mail to one
# real inbox for demos (Resend sandbox only delivers to your account email).
# Example: DEMO_EMAIL_TO=you@gmail.com
DEMO_EMAIL_TO=

# Branding used in generated customer emails
COMPANY_NAME=Aurora Freight

# Survey welcome emails (Resend — https://resend.com)
FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000

# Models (see CLAUDE skill: Opus 4.8 reasoning, Sonnet 4.6 emails)
REASONING_MODEL=claude-opus-4-8
EMAIL_MODEL=claude-sonnet-4-6