# Copy to .env and fill in. The app reads these at startup.

# Claude API key (required for the AI agent endpoints)
ANTHROPIC_API_KEY=sk-ant-...

# Database. Defaults to a local SQLite file so the app runs with zero setup.
# For Postgres (the production target), use e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ai_trucking
DATABASE_URL=sqlite:///./ai_trucking.db

# Branding used in generated customer emails
COMPANY_NAME=Aurora Freight

# Models (see CLAUDE skill: Opus 4.8 reasoning, Sonnet 4.6 emails)
REASONING_MODEL=claude-opus-4-8
EMAIL_MODEL=claude-sonnet-4-6
